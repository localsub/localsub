{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "LocalSub",
  "version": "0.1.1",
  "identifier": "com.localsub.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalSub",
        "width": 1200,
        "height": 860,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/localsub/localsub/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDAzMTk5QTI4Q0MyRjBEQTAKUldTZ0RTL01LSm9aQS9EVitjYW9hZUloRjUyTnhKaGxFemdxRWtmTFFNdzZURVVQYlQ0MGpudVUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/python-embed/*": "python-embed/",
      "resources/get-pip.py": "get-pip.py",
      "resources/python-server/*": "python-server/",
      "resources/model_catalog.json": "model_catalog.json",
      "resources/integrity.json": "integrity.json",
      "resources/cuda_selftest.gguf": "cuda_selftest.gguf",
      "resources/default_vocabularies/*": "default_vocabularies/"
    }
  }
}
