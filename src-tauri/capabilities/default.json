{
  "$schema": "https://raw.githubusercontent.com/nickkuk/nickkuk.github.io/master/tauri-v2/capabilities-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "dialog:allow-open",
    "notification:default",
    "updater:default"
  ]
}
